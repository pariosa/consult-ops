{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:vue/vue3-recommended",
    "prettier",
    "plugin:storybook/recommended"
  ],
  "plugins": [
    "vue"
  ],
  "rules": {
    "no-console": "warn",
    "vue/multi-word-component-names": "off"
  }
}